// Test fixture: flow-level lumon { ... } block (DSL-016).
flow lumon_block_pipeline {
    budget = 1h
    on_error = pause
    context = handoff
    lumon {
        enabled = true
        plugins = ["sample"]
    }

    input {
        task_name: string
    }

    entry start { prompt = "begin" }
    task work { prompt = "do work" }
    exit done { prompt = "wrap up" }

    start -> work
    work -> done
}
