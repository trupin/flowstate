// Test fixture: L1 — ``plugins`` (or ``config``) requires ``enabled = true``
// at the same scope. (DSL-016)
flow lumon_block_l1 {
    budget = 1h
    on_error = pause
    context = handoff
    lumon {
        plugins = ["sample"]
    }

    input {
        task_name: string
    }

    entry start { prompt = "begin" }
    exit done { prompt = "wrap up" }

    start -> done
}
