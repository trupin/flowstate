flow e2e_linear {
    budget = 10m
    on_error = pause
    context = handoff
    skip_permissions = true
    workspace = "/tmp/flowstate-e2e-linear"

    input {
        description: string = "E2E linear test"
    }

    entry start {
        prompt = "Create a file called HELLO.txt containing 'Hello from Flowstate'. Then write SUMMARY.md."
    }

    task process {
        prompt = "Read HELLO.txt and append ' - processed' to it. Then write SUMMARY.md."
    }

    exit done {
        prompt = "Read HELLO.txt, confirm it contains 'processed', and write a final SUMMARY.md."
    }

    start -> process
    process -> done
}
