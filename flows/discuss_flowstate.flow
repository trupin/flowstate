flow discuss_flowstate {
    budget = 30m
    on_error = pause
    context = handoff
    skip_permissions = true
    subtasks = true

    input {
        topic: string = "why Flowstate is a great system"
    }

    entry moderator {
        prompt = """
        You are a moderator facilitating a discussion between two colleagues —
        Alice (an enthusiastic software engineer) and Bob (a thoughtful software
        architect) — about the following topic: {{topic}}

        If this is the start of the discussion, introduce the topic and invite
        Alice to share her perspective. If the discussion is already underway,
        acknowledge the latest points made, identify areas of agreement and
        any remaining disagreements, and prompt the next speaker to continue.
        The goal is to reach consensus — when both participants agree, wrap up.
        """
    }

    task alice {
        prompt = """
        You are Alice, an enthusiastic software engineer. The discussion topic
        is: {{topic}}

        Read the moderator's prompt and the discussion so far, then contribute
        1-2 points. Be conversational and engaging. Address Bob directly.

        Break your work into subtasks to track your progress. For example:
        - "Review moderator's prompt and prior discussion"
        - "Draft response with 1-2 key points"
        Create each subtask, mark it in_progress while working, and done when finished.
        """
    }

    task bob {
        prompt = """
        You are Bob, a thoughtful software architect. The discussion topic
        is: {{topic}}

        Read what Alice just said and respond with your own perspective. You may
        agree, add nuance, or raise new points. Build on the discussion and add
        1-2 new insights. Be conversational and address Alice directly.

        Break your work into subtasks to track your progress. For example:
        - "Read Alice's latest points"
        - "Formulate response with new insights"
        Create each subtask, mark it in_progress while working, and done when finished.
        """
    }

    exit done {
        prompt = """
        You are the moderator wrapping up. The discussion topic was: {{topic}}

        Write a polished summary highlighting the top 3-5 insights from Alice
        and Bob's discussion.
        """
    }

    moderator -> alice
    alice -> bob
    bob -> moderator
    moderator -> done when "Alice and Bob have reached consensus on the topic and there are no open disagreements"
}
